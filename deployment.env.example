# This is documentation only. GitHub Actions creates /opt/ghost/.env from secrets.
DOCKERHUB_USERNAME=your-dockerhub-user
IMAGE_NAME=ghost-custom
IMAGE_TAG=latest
GHOST_URL=http://your-ec2-host
GHOST_PORT=80
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-value
MYSQL_PASSWORD=replace-with-a-different-long-random-value
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-value
# Keep dashboards private and use: ssh -L 3000:localhost:3000 -L 9090:localhost:9090 ubuntu@host
MONITORING_BIND_ADDRESS=127.0.0.1
PROMETHEUS_RETENTION=15d
